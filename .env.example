# Copy this file to .env and edit credentials before running:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=opspilot_pass
POSTGRES_DB=opspilotdb
POSTGRES_PORT=5433

# Application port (host side)
APP_PORT=5010

# llama.cpp endpoints (used by the app container in docker-compose)
# These default to host.docker.internal so a llama.cpp running on the host is reachable.
LLAMA_SQL_BASE_URL=http://host.docker.internal:8080
LLAMA_EMBEDDING_BASE_URL=http://host.docker.internal:8081
